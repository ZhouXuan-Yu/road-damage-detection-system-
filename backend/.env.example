# ===========================================
# 道路病害智能检测系统 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入实际值

# ===========================================
# 应用配置
# ===========================================
APP_NAME=Road Damage Detection System
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ===========================================
# 文件路径配置
# ===========================================
# YOLO 模型权重文件路径
# 请将你的 best.pt 模型文件放在 backend/weights/ 目录下
WEIGHTS_PATH=./weights/best.pt

# 上传文件存储目录
UPLOADS_DIR=./uploads

# 检测结果存储目录
RESULTS_DIR=./results

# 报告输出目录
REPORTS_DIR=./reports

# ===========================================
# 数据库配置
# ===========================================
# SQLite 开发环境
DATABASE_URL=sqlite+aiosqlite:///./detections.db

# PostgreSQL 生产环境（可选）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/road_damage

# ===========================================
# 检测参数
# ===========================================
# 默认置信度阈值 (0.0 - 1.0)
DEFAULT_CONFIDENCE=0.25

# 默认 IoU 阈值 (0.0 - 1.0)
DEFAULT_IOU=0.45

# 视频检测跳帧数（每 N 帧检测一次）
VIDEO_FRAME_SKIP=5

# ===========================================
# AI / LLM 配置
# ===========================================
# DeepSeek API Key（从 https://platform.deepseek.com/ 获取）
OPENAI_API_KEY=your-deepseek-api-key-here

# DeepSeek API 地址
OPENAI_BASE_URL=https://api.deepseek.com

# LLM 模型名称
LLM_MODEL=deepseek-chat

# ===========================================
# Neo4j 图数据库配置（可选，用于知识图谱）
# ===========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
